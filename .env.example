# Copy to .env and adjust. Used by docker-compose.

# Postgres password (compose builds DATABASE_URL from this).
DB_PASSWORD=checkpoint

# Secret used to sign JWTs. Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated allowed CORS origins (the web client).
CORS_ORIGINS=http://localhost:5173

# Seed the demo data on first API start (demo@checkpoint.local / checkpoint).
SEED_ON_START=true

# Base URL the web client uses to reach the API (from the browser).
VITE_API_BASE=http://localhost:8000/api

# Google sign-in (optional). Create an OAuth 2.0 Client ID (type "Web application")
# in Google Cloud Console, add http://localhost:5173 as an authorized JS origin,
# then put the SAME client id in both vars. Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
