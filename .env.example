# Copy to .env and adjust. Used by docker-compose.

# Postgres password (compose builds DATABASE_URL from this). Generate a
# URL-safe value, for example: openssl rand -hex 24
DB_PASSWORD=

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated allowed CORS origins (the web client).
CORS_ORIGINS=https://infiniteai.space,https://www.infiniteai.space,http://localhost:5173

# Demo seeding is blocked when APP_ENV=production.
SEED_ON_START=false

# Base URL the web client uses to reach the API (from the browser).
VITE_API_BASE=https://api.infiniteai.space/api

# Google sign-in (optional). Create an OAuth 2.0 Client ID (type "Web application")
# in Google Cloud Console, add https://infiniteai.space as an authorized JS origin
# (and http://localhost:5173 for local dev), then put the SAME client id in both vars.
# Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Google Calendar connect (optional, read-only event mirror). Requires the same
# OAuth client as above PLUS its client secret (server-side code exchange) and a
# token-encryption key. Enable the Google Calendar API on the project and add the
# .../auth/calendar.readonly scope to the consent screen (a "sensitive" scope —
# keep the app in Testing mode with your friends as test users to skip
# verification). Leave either blank to disable calendar connect.
GOOGLE_CLIENT_SECRET=
# Fernet key encrypting secrets at rest: Google Calendar OAuth tokens AND the
# two-step verification (TOTP) authenticator secret. Setting it also enables the
# optional two-step verification feature; leaving it blank disables both.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Web Push reminders (ADR-001) --------------------------------------------
# VAPID keypair identifying this server to browser push services, enabling
# active reminders (task pings + the resume nudge). Reminders also need
# TOKEN_ENCRYPTION_KEY above (subscription endpoints are encrypted at rest).
# Leave blank to keep the whole reminder subsystem dark.
# Generate a keypair with:  python ops/gen-vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# The VAPID "sub" claim — a mailto: or https: URL the push service can use to
# reach you about this application server.
VAPID_SUBJECT=mailto:you@example.com
