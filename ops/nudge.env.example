# Config for ops/nudge-checkpoint.sh — the daily off-app "return cue".
# Copy to ops/nudge.env and adjust. Loaded automatically (override the path
# with NUDGE_ENV_FILE=/some/where.env).
#
# No app secrets needed: the script reads Postgres read-only inside the
# container, exactly like ops/backup-checkpoint.sh.
#
# Crontab (single path — runs once a day; the script self-guards to one send):
#   0 8 * * *  /home/mohammad/home-projects/ops/nudge-checkpoint.sh >> /var/log/checkpoint-nudge.log 2>&1
# Pick the hour that matches where your attention is (NUDGE_AT below is just a
# reminder of your chosen cron time — the cron schedule is what actually fires).

# --- where things live on the server (match ops/backup.env) ------------------
PROJECT_ROOT=/home/mohammad/home-projects
COMPOSE_FILE=/home/mohammad/home-projects/docker-compose.yaml
POSTGRES_SERVICE=checkpoint-postgres
DB_NAME=checkpoint
DB_USER=checkpoint
# Only if your container's pg_hba.conf doesn't trust local connections.
DB_PASSWORD=

# --- whose thread to nudge (set exactly one; owner id wins) -------------------
# NUDGE_OWNER_ID=00000000-0000-0000-0000-000000000000
NUDGE_EMAIL=mohammad.akhavan75@gmail.com

# --- presentation -------------------------------------------------------------
NUDGE_NAME=Mohammad
NUDGE_APP_URL=https://checkpoint.example.com
# IANA timezone used to compute "today" (so the nudge respects your calendar day).
NUDGE_TZ=Europe/Berlin
# Informational: the hour you scheduled the cron line for (not enforced here).
NUDGE_AT=08:00

# --- channel: stdout | telegram | webhook | osascript ------------------------
NUDGE_CHANNEL=telegram
# Set true to print the message instead of sending (test without a live channel).
NUDGE_DRY_RUN=false

# telegram: create a bot via @BotFather, then message it once to get your chat id.
NUDGE_TELEGRAM_TOKEN=
NUDGE_TELEGRAM_CHAT_ID=

# webhook: Slack/Mattermost incoming webhook (key "text") or Discord (key
# "content"). One POST, no SMTP, no domain.
NUDGE_WEBHOOK_URL=
NUDGE_WEBHOOK_JSON_KEY=text

# osascript: macOS local notification — only useful if cron runs on your own Mac.

# --- back-off (never escalates) ----------------------------------------------
# After this many consecutive ignored nudges, drop from daily to once every
# NUDGE_BACKOFF_INTERVAL_DAYS. Returning (a checkpoint) resets it to daily.
NUDGE_BACKOFF_AFTER=3
NUDGE_BACKOFF_INTERVAL_DAYS=7

# Where the last-sent date + back-off counter live (read-only DB; this is the
# only thing the script writes). Defaults next to the script.
# NUDGE_STATE_FILE=/home/mohammad/home-projects/ops/.nudge-state
