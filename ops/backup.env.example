# Config for ops/backup-checkpoint.sh and ops/restore-checkpoint.sh.
# Copy to ops/backup.env and adjust. Loaded automatically by both scripts
# (override the path with BACKUP_ENV_FILE=/some/where.env).
#
# This file holds operational config only — no app secrets are required here
# unless your Postgres rejects local trust auth (see DB_PASSWORD below).

# --- where things live on the server -----------------------------------------
# Match ops/deploy-checkpoint.sh. The compose file and service names below are
# the production (checkpoint-*) names; for a local `docker compose` checkout use
# COMPOSE_FILE=./docker-compose.yml and POSTGRES_SERVICE=postgres / API_SERVICE=api.
PROJECT_ROOT=/home/mohammad/home-projects
COMPOSE_FILE=/home/mohammad/home-projects/docker-compose.yaml
POSTGRES_SERVICE=checkpoint-postgres
API_SERVICE=checkpoint-api

# --- database -----------------------------------------------------------------
DB_NAME=checkpoint
DB_USER=checkpoint
# Only needed if your pg_hba.conf does not trust local connections inside the
# container (the official postgres image trusts them, so this is usually blank).
DB_PASSWORD=

# --- local backup store -------------------------------------------------------
BACKUP_DIR=/home/mohammad/home-projects/backups
# Keep this many newest local dumps; older local dumps are pruned each run.
KEEP_LOCAL=14

# --- Google Drive upload (rclone) ---------------------------------------------
# Set SKIP_UPLOAD=true to keep backups local only.
SKIP_UPLOAD=false
# rclone remote + path. Create the remote per docs/ops/BACKUP_RESTORE.md.
# Example: gdrive-checkpoint:checkpoint-backups
RCLONE_REMOTE=gdrive-checkpoint:checkpoint-backups
# Optional explicit rclone config path (else rclone's default ~/.config/rclone).
RCLONE_CONFIG=
# Delete remote dumps older than this many days (blank = never prune remote).
KEEP_REMOTE_DAYS=30
